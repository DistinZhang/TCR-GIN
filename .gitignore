models/
*.pt
*.pth
*.ckpt
*.pkl
*.pickle
*.npy
*.npz

# Experiment-local generated artifacts
experiments/**/models/
experiments/**/outputs/
experiments/**/results/
experiments/**/cache/

# Keep the small bundled Streamlit demo assets.
!webapp/examples/transport_demo/network/
!webapp/examples/transport_demo/network/*.npz
!webapp/examples/transport_demo/models/
